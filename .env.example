# Copy to .env and adjust. Used by docker compose.

# Password for the bundled Postgres container.
POSTGRES_PASSWORD=designer

# Secret used to sign session JWTs. MUST be at least 16 characters; use a long random value.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Published image tag to run (self-host stack). e.g. latest or a version like 1.2.3
IMAGE_TAG=latest

# Host port to expose the app on (http://localhost:APP_PORT).
APP_PORT=3000

# Backend log verbosity: fatal | error | warn | info | debug | trace | silent (default info).
# Use debug to trace schema-import connection/query steps.
LOG_LEVEL=info
